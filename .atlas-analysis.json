  "keyFeatures": [
    "AES-256-GCM encryption with password, platform key, or recovery key slots",
    "Content-addressable storage with deduplication across sources",
    "Incremental backups using FastCDC chunking",
    "Multiple sources: Google Drive, OneDrive, local directories, SFTP",
    "Multiple backends: local filesystem, Amazon S3, Backblaze B2, SFTP",
    "Retention policies: keep-last, hourly, daily, weekly, monthly, yearly",
    "Point-in-time restore with ZIP archive output",
    "HAMT-based merkle tree for efficient snapshot management"
  ],
